# vellora — "1 command → PDF" demo image.
#
# Build the workspace (cargo + the @vellora/native addon + TypeScript) in a
# builder stage, then run the invoice example to emit a PDF.
#
#   docker build -f Dockerfile.example -t vellora-example .
#   docker run --rm vellora-example
#
# The container renders fixtures/invoice via examples/render-invoice.ts and
# prints the byte count + a verified %PDF- header.

# --- builder: Rust toolchain + Node, full workspace build ---
FROM rust:1.96.0-bookworm AS builder

# Node 22 (pinned via .nvmrc) on top of the Rust image.
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install JS deps first for layer caching.
COPY package.json package-lock.json ./
COPY packages ./packages
RUN npm install

# Bring in the rest and build: cargo (release) + napi addon + TypeScript.
COPY . .
RUN npm run build

# --- runtime: render the invoice example in one command ---
FROM node:22-bookworm-slim AS runtime
WORKDIR /app
COPY --from=builder /app ./
CMD ["npm", "run", "example"]
