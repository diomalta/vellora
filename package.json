{
  "name": "vellora-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "cargo build --release && npm -w @vellora/native run build:addon && npm run build:ts",
    "build:ts": "npm -w @vellora/lint run build && npm -w @vellora/native run build && npm -w @vellora/test-harness run build && npm -w vellora run build && npm -w @vellora/cli run build",
    "test": "npm run test:rust && npm run test:ts",
    "test:rust": "cargo test",
    "test:ts": "vitest run",
    "lint": "npm run lint:rust && npm run lint:ts",
    "lint:rust": "cargo clippy --all-targets -- -D warnings && cargo fmt --check",
    "lint:ts": "biome check .",
    "format": "biome format --write . && cargo fmt",
    "clean": "rm -rf target packages/*/dist && rm -f packages/native/*.node packages/native/index.d.ts packages/native/index.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "example": "tsx examples/render-invoice.ts",
    "render-receipt": "tsx examples/render-receipt.ts",
    "render-boleto": "tsx examples/render-boleto.ts",
    "render-notification": "tsx examples/render-notification.ts",
    "render-to-http-stream": "tsx examples/render-to-http-stream.ts",
    "batch-concurrency": "tsx examples/batch-concurrency.ts",
    "visual:fixtures": "node scripts/render-visual-fixtures.mjs",
    "geometry:fidelity": "npm --prefix benchmarks run geometry:fidelity --",
    "visual:fidelity": "npm --prefix benchmarks run visual:fidelity --",
    "compat:gen": "node scripts/gen-compatibility.mjs",
    "compat:check": "node scripts/gen-compatibility.mjs --check",
    "docs:api": "typedoc",
    "docs:dev": "vitepress dev docs",
    "docs:build": "npm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.4.0",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.3",
    "vitest": "^2.1.0"
  }
}
