packages/native/index.d.ts
packages/native/index.js

# Transient test scratch dirs (real-native determinism gate; auto-removed, ignored as a safety net)
.determinism-native-*/
benchmarks/results/geometry-fidelity/
benchmarks/results/visual-fidelity/

# OS
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Local agent / tooling state (not part of the library)
.claude/
.codex/
.remember/
openspec/

# Env
.env
.env.local
examples/out/
