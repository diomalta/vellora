{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": false },
  "files": {
    "ignore": [
      "**/dist",
      "**/target",
      "**/*.node",
      "packages/native/index.d.ts",
      "packages/native/index.js",
      "openspec",
      "fixtures",
      "benchmarks/results/visual-fidelity",
      ".remember",
      ".codex",
      ".claude"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always" }
  }
}
